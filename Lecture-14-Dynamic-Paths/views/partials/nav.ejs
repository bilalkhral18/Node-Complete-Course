<header>
  <div class="bg-[#b14400] p-4">
    <span class="ml-8 flex gap-x-[2rem] text-white">
      <a
        href="/"
        class="<%= currentPage === 'airbnb index' ? 'bg-red-300 rounded px-4 py-1' : '' %>"
      >
        Airbnb
      </a>
      <a
        href="/favourites"
        class="<%= currentPage === 'favourites' ? 'bg-red-300 rounded px-4 py-1' : '' %>"
      >
        Favourites
      </a>
      <a
        href="/bookings"
        class="<%= currentPage=== 'bookings' ? 'bg-red-300 rounded px-4 py-1' : '' %>"
      >
        Bookings
      </a>
      <a
        href="/homes"
        class="<%= currentPage=== 'home-list' ? 'bg-red-300 rounded px-4 py-1' : '' %>"
      >
        Home List
      </a>
      <a
        href="/host/host-home-list"
        class="<%= currentPage=== 'host-home-list' ? 'bg-red-300 rounded px-4 py-1' : '' %>"
      >
        Host Homes
      </a>
      <a
        href="/host/add-home"
        class="<%= currentPage === 'Add Home — Airbnb' ? 'bg-red-300 rounded px-4 py-1' : '' %>"
      >
        Add Home
      </a>
    </span>
  </div>
</header>
