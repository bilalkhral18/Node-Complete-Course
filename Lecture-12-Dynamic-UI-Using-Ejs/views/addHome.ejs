<%- include("./partials/head")%>
  </head>
  <body>
    <%- include("./partials/nav")%>

    <main>
      <div class="flex justify-center mt-12 w-screen">
        <form
          action="/host/add-home"
          method="post"
          class="flex flex-col shadow-xl px-40 rounded-xl py-9 gap-y-3 w-[60%]"
        >
          <h1 class="font-bold text-lg text-center">
            Register Your Home On Airbnb
          </h1>
          <input
            type="text"
            placeholder="Enter Your Home Address"
            name="houseName"
            class="focus:outline-2 outline-[1px] outline-orange-400 focus:outline-orange-400 px-2 pr-12 rounded py-1"
          />
          <input
            type="number"
            placeholder="price per night"
            name="price"
            class="focus:outline-2 outline-[1px] outline-orange-400 focus:outline-orange-400 px-2 pr-12 rounded py-1"
          />
          <input
            type="text"
            placeholder="Enter Your Home Location"
            name="Location"
            class="focus:outline-2 outline-[1px] outline-orange-400 focus:outline-orange-400 px-2 pr-12 rounded py-1"
          />
          <input
            type="text"
            placeholder="Ratings..."
            name="Rating"
            class="focus:outline-2 outline-[1px] outline-orange-400 focus:outline-orange-400 px-2 pr-12 rounded py-1"
          />
          <input
            type="image"
            placeholder="upload image"
            name="Image"
            class="focus:outline-2 outline-[1px] outline-orange-400 focus:outline-orange-400 px-2 pr-12 rounded py-1"
          />
          <button class="bg-orange-500 rounded py-1 cursor-pointer">
            Register
          </button>
        </form>
      </div>
    </main>
  </body>
</html>
