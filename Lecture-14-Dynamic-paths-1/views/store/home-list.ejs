<%- include("../partials/head")%>
  </head>
  <body>
    <%- include("../partials/nav")%>
    <main class="mt-12 flex justify-center">
  <div class="w-full max-w-3xl bg-white shadow-2xl rounded-2xl p-10">
    
    <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">
      Here are the list of homes
    </h2>

  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 py-4">
  <% homes?.forEach((home, i) => { %>
    <li class="group cursor-pointer">
      
      <!-- Image -->
      <div class="relative rounded-2xl overflow-hidden aspect-square">
        <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>">

        <!-- Badge -->
        <span class="absolute top-3 left-3 bg-white text-gray-800 text-xs font-semibold px-3 py-1.5 rounded-full">
          Guest favorite
        </span>

        <!-- Heart -->
        <button class="absolute top-2.5 right-2.5 p-1.5 group/heart">
          <svg class="w-6 h-6 transition-transform duration-200 group-hover/heart:scale-110" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 28c-1.5-1.4-10-8.5-10-15a7 7 0 0 1 10-6.3A7 7 0 0 1 26 13c0 6.5-8.5 13.6-10 15z"
              fill="rgba(0,0,0,0.35)" stroke="white" stroke-width="1.5"/>
          </svg>
        </button>
      </div>

      <!-- Info -->
      <div class="pt-3 px-0.5 space-y-0.5">
        <div class="flex justify-between items-center">
          <h3 class="text-sm font-semibold text-gray-900 truncate max-w-[72%]"><%= home.houseName %></h3>
          <div class="flex items-center gap-1 text-sm font-medium text-gray-900 shrink-0">
            <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <%= home.rating %>
          </div>
        </div>
        <p class="text-sm text-gray-500"><%= home.Location %></p>
        <p class="text-sm text-gray-500">Available year round</p>
        <p class="text-sm text-gray-900 pt-1">
          <span class="font-semibold"><%= home.price %></span>
          <span class="text-gray-500 font-normal"> / night</span>
        </p>
      </div>
    <%- include("../partials/favourites" , {home:home})%>   
    <a href="/homes/<%= home.id %>"><button class="bg-blue-600  p-1 px-5 rounded-2xl mt-4" >Details</button></a>
    </li>
  <% }) %>
</ul>

  </div>
</main>
  </body>
</html>
