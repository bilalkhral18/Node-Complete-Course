<%- include("../partials/head")%>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    .font-playfair { font-family: 'Playfair Display', serif; }
    .font-dm { font-family: 'DM Sans', sans-serif; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeUp { animation: fadeUp 0.6s ease both; }
    .gradient-divider {
      height: 1px;
      background: linear-gradient(to right, #e8d5a3, transparent);
    }
  </style>
  </head>

  <body class="font-dm" style="background-color: #f7f3ee; color: #1a1a1a;">
    <%- include("../partials/nav")%>

    <main class="min-h-screen flex justify-center px-6 py-12 pb-20">
      <div class="animate-fadeUp w-full max-w-3xl bg-white rounded-3xl overflow-hidden shadow-lg">

        <!-- Image -->
        <div class="relative w-full h-96 overflow-hidden group">
          <img
            src="<%= home.photoUrl %>"
            alt="<%= home.houseName %>"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <!-- Overlay -->
          <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 40%, rgba(26,26,26,0.55) 100%);"></div>
          <!-- Badge -->
          <span class="absolute top-5 left-5 bg-white bg-opacity-90 backdrop-blur text-xs font-medium tracking-widest uppercase px-4 py-1.5 rounded-full" style="color: #1a1a1a;">
            Guest Favourite
          </span>
        </div>

        <!-- Body -->
        <div class="px-12 pt-10 pb-12">

          <!-- Name + Rating pill -->
          <div class="flex items-start justify-between gap-4 mb-2">
            <h1 class="font-playfair text-4xl font-bold leading-tight" style="color: #1a1a1a;">
              <%= home.houseName %>
            </h1>
            <div class="flex items-center gap-2 shrink-0 text-white text-sm font-medium px-4 py-2 rounded-full" style="background-color: #1a1a1a;">
              <svg class="w-3 h-3" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" style="fill: #c9a84c;">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              Ratings: <%= home.rating %>
            </div>
          </div>

          <!-- Divider -->
          <div class="gradient-divider my-6"></div>

          <!-- Info Grid -->
          <div class="grid grid-cols-2 gap-5 mb-8">
            <!-- Location -->
            <div class="flex flex-col gap-1 rounded-2xl p-5" style="background-color: #f7f3ee;">
              <span class="text-xs font-medium tracking-widest uppercase" style="color: #6b6560;">Location</span>
              <span class="font-playfair text-xl font-bold" style="color: #1a1a1a;"><%= home.price %></span>
            </div>
            <!-- Price -->
            <div class="flex flex-col gap-1 rounded-2xl p-5" style="background-color: #f7f3ee;">
              <span class="text-xs font-medium tracking-widest uppercase" style="color: #6b6560;">Price per night</span>
              <span class="font-playfair text-xl font-bold" style="color: #c9a84c;">$<%= home.location %></span>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-wrap gap-4">
    
<%- include("../partials/favourites" , {home:home}) %>            
            <a
              href="/homes"
              class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 hover:opacity-90 active:translate-y-0"
              style="border: 1.5px solid #d4cfc9; color: #1a1a1a;"
            >
              ← Back to listings
            </a>
          </div>

        </div>
      </div>
    </main>

  </body>
</html>
